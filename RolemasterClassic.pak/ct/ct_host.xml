<root>
	<template name="button_ct_controls_menu" merge="join">
		<button_listitem_text_left_sm>
			<script file="ct/scripts/ct_menu.lua" />
		</button_listitem_text_left_sm>
	</template>

	<windowclass name="combattracker_host" merge="join">
		<sizelimits>
			<minimum width="675" />
		</sizelimits>
		<script file="ct/scripts/ct_window_dnd.lua" />
	</windowclass>
	<windowclass name="sub_ct_header_host" merge="join">
		<sheetdata>
			<spacer_ct_header_right name="spacer_buttons_header_add" insertbefore="label_init">
				<anchored width="60" />
			</spacer_ct_header_right>

			<label_ct_header_right name="label_damage" insertbefore="label_init">
				<static textres="ct_label_damage" />
			</label_ct_header_right>
			<label_ct_header_right name="label_hits" insertbefore="label_init">
				<static textres="ct_label_hits" />
			</label_ct_header_right>
			<label_ct_header_right name="label_used_pp" insertbefore="label_init">
				<static textres="ct_label_used_pp" />
			</label_ct_header_right>
			<label_ct_header_right name="label_max_pp" insertbefore="label_init">
				<static textres="ct_label_max_pp" />
			</label_ct_header_right>
			<label_ct_header_right name="label_activitypercent" insertbefore="label_init">
				<static textres="ct_label_activitypercent" />
			</label_ct_header_right>
		</sheetdata>
	</windowclass>
</root>
