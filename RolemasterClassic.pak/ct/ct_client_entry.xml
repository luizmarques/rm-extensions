<root>
	<template name="number_ct_activitypercent">
		<basicnumber>
			<anchored width="25" height="20" />
		</basicnumber>
	</template>

	<windowclass name="client_ct_entry" merge="join">
		<script file="ct/scripts/clientct_entry.lua" />
		<sheetdata>
			<hn name="tokenvis" />

			<hn name="quicknessBonus" />
			<hn name="quicknessStat" />

			<hs name="owner">
				<script>
					function onValueChanged()
						window.onOwnerChanged();
					end
				</script>
			</hs>

			<buttonfield name="turncomplete">
				<anchored to="token" position="insidetopleft" offset="-3,-2" width="12" height="12"/>
				<state icon="indicator_turnos" />
				<state icon="indicator_turntaken" />
			</buttonfield>

			<button_ct_section_defense name="button_section_defense" insertbefore="friendfoe" />
			<spacer_button_ct_section name="spacer_button_section_defense" insertbefore="friendfoe" />
			<button_ct_section_active name="button_section_active" insertbefore="friendfoe" />
			<spacer_button_ct_section name="spacer_button_section_active" insertbefore="friendfoe" />
			<button_ct_section_move name="button_section_move" insertbefore="friendfoe" />
			<spacer_button_ct_section name="spacer_button_section_move" insertbefore="friendfoe" />

			<string_clientct_status name="status" insertbefore="initresult" />
			<number_ct_static name="damage" insertbefore="initresult">
				<anchored to="rightanchor" width="30" height="20">
					<top />
					<right anchor="left" relation="relative" offset="-10" />
				</anchored>
				<min value="0" />
				<script>
					function update()
						window.onHealthChanged();
					end
					function onDrop(x, y, draginfo)
						if draginfo.isType("number") then
							setValue(getValue() + draginfo.getNumberData());
							return true;
						end
					end
				</script>
			</number_ct_static>
			<number_ct_static name="hits" insertbefore="initresult">
				<anchored to="rightanchor" width="30" height="20">
					<top />
					<right anchor="left" relation="relative" offset="-10" />
				</anchored>
				<min value="0" />
				<script>
					function update()
						window.onHealthChanged();
					end
				</script>
			</number_ct_static>
			<number_ct_static name="ppcurrent" insertbefore="initresult">
				<anchored to="rightanchor" width="30" height="20">
					<top />
					<right anchor="left" relation="relative" offset="-10" />
				</anchored>
				<min value="0" />
				<script>
					function onInit()
						if super and super.onInit then
							super.onInit();
						end
						onValueChanged();
					end

					function onValueChanged()
						if getValue() &lt; 0 or getValue() &gt; window.ppmax.getValue() then
							setColor(ColorManager.getUIColor("field_error"));
						else
							setColor(nil);
						end
					end

					function onDrop(x, y, draginfo)
						if window.onDrop(x,y,draginfo) then
							return true;
						end
						if draginfo.isType("number") then
							if linknode then
								linknode.setValue(getValue() + draginfo.getNumberData());
							else
								setValue(getValue() + draginfo.getNumberData());
							end
						end
						return true;
					end
				</script>
			</number_ct_static>
			<number_spelladdermax name="spelladderused" insertbefore="initresult">
				<anchored to="ppcurrent" />
				<tooltip textres="tooltip_used_spell_adder" />
			</number_spelladdermax>
			<number_ct_static name="ppmax" insertbefore="initresult">
				<anchored to="rightanchor" width="30" height="20">
					<top />
					<right anchor="left" relation="relative" offset="-10" />
				</anchored>
				<min value="0" />
				<nodrop />
			</number_ct_static>
			<number_spelladdermax name="spelladdermax" insertbefore="initresult">
				<anchored to="ppmax" />
				<tooltip textres="tooltip_max_spell_adder" />
				<readonly />
			</number_spelladdermax>
			<number_ct_activitypercent name="activitypercent" insertbefore="initresult">
				<anchored to="rightanchor" width="30" height="20">
					<top />
					<right anchor="left" relation="relative" offset="-10" />
				</anchored>
				<min value="0" />
				<hideonvalue value="0" />
			</number_ct_activitypercent>

			<number_clientct_init name="initresult">
				<script>
					function action(draginfo)
						local nodeCT = window.getDatabaseNode();
						local bOwner = CombatManager2.isCTEntryOwner(nodeCT);
						if bOwner then
							local rActor = ActorManager.resolveActor(window.getDatabaseNode());
							ActionInitiative.performRoll(draginfo, rActor);
							return true;
						end
					end
					function onDragStart(button, x, y, draginfo)
						return action(draginfo);
					end
					function onDoubleClick(x,y)
						return action();
					end
				</script>
			</number_clientct_init>
			
			<sub_ct_section name="sub_move" insertbefore="sub_effects" />
			<sub_ct_section name="sub_active" insertbefore="sub_effects" />
			<sub_ct_section name="sub_defense" insertbefore="sub_effects" />
		</sheetdata>
	</windowclass>
</root>
