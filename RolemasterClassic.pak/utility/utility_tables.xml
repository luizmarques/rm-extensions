	<!-- subwindow which displays the actual table contents -->
	<windowclass name="tableview_window">
		<script file="utility/scripts/tableview_window.lua"/>
		<sheetdata>
			<stringcontrol name="titlebar">
				<frame>
					<name>rowshade</name>
					<offset>0,0,0,-1</offset>
				</frame>
				<anchored height="13">
					<top>
						<anchor>top</anchor>
					</top>
					<left>
						<anchor>left</anchor>
					</left>
					<right>
						<anchor>right</anchor>
					</right>
				</anchored>
				<font>sheetlabelsmall</font>
				<center/>
				<static/>
			</stringcontrol>
			<genericcontrol name="grid">
				<anchored>
					<top>
						<parent>titlebar</parent>
						<anchor>bottom</anchor>
						<relation>relative</relation>
					</top>
					<left>
						<anchor>left</anchor>
					</left>
					<right>
						<anchor>right</anchor>
						<offset>-15</offset>
					</right>
					<bottom>
						<anchor>bottom</anchor>
						<offset>-15</offset>
					</bottom>
				</anchored>
				<frame>
					<name>rowshade</name>
				</frame>
				<disabled />
			</genericcontrol>
			<scrollbar2 name="vbar">
				<target>grid</target>
			</scrollbar2>
			<scrollbar2 name="hbar">
				<target>grid</target>
				<horizontal/>
			</scrollbar2>
			<button_text name="button_applyresult">
				<anchored position="insidetopleft" offset="7,7" width="50" height="20" />
				<textres>tr_label_apply</textres>
				<tooltip textres="tr_tooltip_tableview_apply" />
				<script>
					function onButtonPress()
						local sAttackerNodeName = window.parentcontrol.window.attackerNodeName.getValue();
						local nodeAttacker = DB.findNode(sAttackerNodeName);
						local sAttackNodeName = window.parentcontrol.window.attackNodeName.getValue();
						local nodeAttack = DB.findNode(sAttackNodeName);
						local sDefenderNodeName = window.parentcontrol.window.defenderNodeName.getValue();
						local nodeDefender = DB.findNode(sDefenderNodeName);
						local sCritTableID = window.parentcontrol.window.critTableID.getValue();
						local sCritTableName = window.parentcontrol.window.critTableName.getValue();
						local sLargeColumnName = window.parentcontrol.window.largeColumnName.getValue();
						local aSelectedTableCell, aFumble = window.getSelectedTableCell();
						local aWoundEffects = RMTableManager.getTableCellWoundEffects(aSelectedTableCell);
						local sText = RMTableManager.getTableCellText(aSelectedTableCell);
						local sApplyButtonMessage = "[APPLY] [Attacker/Actor: " .. DB.getValue(nodeAttacker, "name", "") .. "]";
						
						if nodeAttacker then
							nodeCTAttacker = ActorManager.getCTNode(nodeAttacker);
							if nodeCTAttacker then
								nodeAttacker = ActorManager.getCTNode(nodeAttacker);
							end
						end
						
						if nodeDefender then
							nodeDefender = ActorManager.getCTNode(nodeDefender);
							sApplyButtonMessage = sApplyButtonMessage .. " [Defender/Target: " .. DB.getValue(nodeDefender, "name", "") .. "]";
						end

						if nodeAttack then
							sApplyButtonMessage = sApplyButtonMessage .. " [Attack Name: " .. DB.getValue(nodeAttack, "name", "") .. "]";
						end
						sApplyButtonMessage = sApplyButtonMessage .. " [Table: " .. window.getTableName() .. "]";
						
						if window.parentcontrol.getName() == "attackgrid" then
							window.parentcontrol.window.resultlist.closeAll();
							sApplyButtonMessage = sApplyButtonMessage .. " [Grid: Attack Table]";
						else
							sApplyButtonMessage = sApplyButtonMessage .. " [Grid: Result Table]";
						end

						local sTRAROption = string.lower(OptionsManager.getOption("TRAR"));
						if aFumble then
							local win = window.parentcontrol.window.resultlist.createWindow();
							win.resulttable.setValue(aFumble.ResultTable);
							win.name.setValue(aFumble.Name);
							win.code.setValue(aFumble.Code);
							win.severity.setValue(aFumble.Severity);
							win.result_name.setValue(aFumble.Severity .. " " .. aFumble.Name);

							sApplyButtonMessage = sApplyButtonMessage .. " [Result: Fumble]";

							window.criticalSelected(aFumble);

							local rActor = ActorManager.resolveActor(nodeAttacker);
							if not ActorManager.isPC(rActor) and (sTRAROption == string.lower(Interface.getString("option_val_fumbles")) 
											or sTRAROption == string.lower(Interface.getString("option_val_first_critical_fumbles")) 
											or sTRAROption == string.lower(Interface.getString("option_val_all_criticals_fumbles"))) then 
								ActionResultTable.performRoll(draginfo, rActor, aFumble.ResultTable);
							end
						else
							local sPrimaryCritResult, aCritList, sOriginalSeverity = RMTableManager.getTableCellResultTable(aSelectedTableCell);
							local aResultTable =  window.parseCritical(sPrimaryCritResult);
							local aCritTableList = {};

							if aSelectedTableCell and aSelectedTableCell.Effects and aSelectedTableCell.Effects[1] then
								if window.parentcontrol.getName() == "attackgrid" then
									if aSelectedTableCell.Effects[1].Criticals and aSelectedTableCell.Effects[1].Criticals[1] then
										if not aSelectedTableCell.Effects[1].RR and not aSelectedTableCell.Effects[1].RRTarget then
											sApplyButtonMessage = sApplyButtonMessage .. " [Result: Critical]";
										end
									else
										if aSelectedTableCell.Effects[1].Hits then
											local nHits = tonumber(aSelectedTableCell.Effects[1].Hits);
											if nHits &gt; 0 then
												sApplyButtonMessage = sApplyButtonMessage .. " [Result: Hit]";
											else
												sApplyButtonMessage = sApplyButtonMessage .. " [Result: Miss]";
											end
										end
									end
								end
							end

							for i, sCritResult in ipairs(aCritList) do
								local aCritTable = window.parseCritical(sCritResult);
								if aCritTable then
									table.insert(aCritTableList, aCritTable);
								end
							end

							if aResultTable and aResultTable.ResultTable ~= Rules_Constants.RRTableID then
								if sCritTableID and sCritTableName and string.len(sCritTableID) &gt; 1 and string.len(sCritTableName) &gt; 1 then
									aResultTable.ResultTable = sCritTableID;
									aResultTable.Name = sCritTableName;
									Comm.deliverChatMessage({icon="icon_info", font="systemfont", text="NOTE: The alternate critical table, " .. sCritTableName .. ", was specified for the attack so it was used instead.", secret=true});
								end
								if string.find(window.getTableClass(), "Spell") then
									sAttackType = "Spell";
								else
									sAttackType = "Arms";
								end
								aResultTable = Rules_NPC.AdjustCritical(nodeDefender, aResultTable, sAttackType, sLargeColumnName, aCritTableList, sOriginalSeverity);
							end

							if aResultTable then
								if aResultTable.ResultTable == Rules_Constants.RRTableID then
									aResultTable.Severity = Rules_Combat.nLevelAttacker;
								else
									local rActor = ActorManager.resolveActor(nodeAttacker);
									if not ActorManager.isPC(rActor) and sTRAROption ~= string.lower(Interface.getString("option_val_none")) 
													and sTRAROption ~= string.lower(Interface.getString("option_val_fumbles")) then 
										ActionResultTable.performRoll(draginfo, rActor, aResultTable.ResultTable);
									end
								end
								
								if aResultTable.Name == "Super-Large" or aResultTable.Name == "Large" then
									local win = window.parentcontrol.window.resultlist.createWindow();
									win.resulttable.setValue(aResultTable.ResultTable);
									win.name.setValue(aResultTable.Name);
									win.code.setValue(aResultTable.Code);
									win.severity.setValue(aResultTable.Severity);
									win.modifier.setValue(aResultTable.Modifier);
									win.result_name.setValue(aResultTable.Severity .. " " .. aResultTable.Name);
								elseif aCritTableList and aCritTableList[1] then
									aCritTableList[1] = aResultTable;
									local nCritSev = Rules_Combat.GetSevNumber(aCritTableList[1].Severity);
									local aAddCrit1 = Rules_Combat.aAddCrit1;
									local aAddCrit2 = Rules_Combat.aAddCrit2;
									if aAddCrit1.Name and string.len(aAddCrit1.Name) > 0 then
										local nAdd1SevAdj = Rules_Combat.nAddCrit1LevelDiff;
										local nAdd1Sev = nCritSev + nAdd1SevAdj;
										aAddCrit1.Severity = Rules_Combat.GetSev(nAdd1Sev);
										if aAddCrit1.Severity and aAddCrit1.Severity ~= "" then
											table.insert(aCritTableList, aAddCrit1);
										end
									end
									if aAddCrit2.Name and string.len(aAddCrit2.Name) > 0 then
										local nAdd2SevAdj = Rules_Combat.nAddCrit2LevelDiff;
										local nAdd2Sev = nCritSev + nAdd2SevAdj;
										aAddCrit2.Severity = Rules_Combat.GetSev(nAdd2Sev);
										if aAddCrit2.Severity and aAddCrit2.Severity ~= "" then
											table.insert(aCritTableList, aAddCrit2);
										end
									end
									
									for _, vCritTable in ipairs(aCritTableList) do
										local win = window.parentcontrol.window.resultlist.createWindow();
										win.resulttable.setValue(vCritTable.ResultTable);
										win.name.setValue(vCritTable.Name);
										win.code.setValue(vCritTable.Code);
										win.severity.setValue(vCritTable.Severity);
										win.modifier.setValue(vCritTable.Modifier);
										win.result_name.setValue(vCritTable.Severity .. " " .. vCritTable.Name);
									end
								end
								window.criticalSelected(aResultTable);
							end
						end 

						Comm.deliverChatMessage({font="systemfont", text=sApplyButtonMessage, secret=true});

						if aSelectedTableCell and aWoundEffects then
							if aResultTable then
								aWoundEffects.CriticalSeverity = aResultTable.Severity;
								aWoundEffects.CriticalName = aResultTable.Name;
								aWoundEffects.CriticalCode = aResultTable.Code;
							end
							local sTableClass = window.getTableClass();
							aWoundEffects.AttackerNodeName = DB.getPath(nodeAttacker);
							if (sTableClass == "Fumbles/Failures" or sTableClass == "Spell Failure") and nodeAttacker then
								local nodeActiveCT = CombatManager.getActiveCT();
								if nodeActiveCT == nodeAttacker then
									CombatManager.nextActor();
								end
								CombatManager2.addWoundEffects(nodeAttacker, aWoundEffects, sText, nodeDefender);
							elseif string.find(window.getTableId(), "CHL10-0") and nodeAttacker then
								local sTRName = window.parentcontrol.window.name.getValue();
								if string.find(sTRName, "Movement MM") then
									local nMovePercent = tonumber(sText) or 0;
									if nMovePercent > 0 then
										DB.setValue(nodeAttacker, "manueverresult", "number", nMovePercent);
									end
								end
								CombatManager2.addWoundEffects(nodeAttacker, aWoundEffects, sText, nodeDefender);
							elseif nodeDefender then
								CombatManager2.addWoundEffects(nodeDefender, aWoundEffects, sText, nodeAttacker);
								
								local rActor = ActorManager.resolveActor(nodeDefender);
								if aWoundEffects.RRTarget and not ActorManager.isPC(rActor) and string.lower(OptionsManager.getOption("TRRR")) == string.lower(Interface.getString("option_val_on")) then
									local nodeCreatureAttacker = ActorManager.getCreatureNode(nodeAttacker);
									local nodeCreatureDefender = ActorManager.getCreatureNode(nodeDefender);
									local sRealm = Rules_PC.Realm(nodeCreatureAttacker);
									local sRRNodeName = Rules_RR.GetRRNodeName(sRealm);
									local nodeRR = nil;

									if sRRNodeName then
										local sNodeRR = DB.getPath(nodeCreatureDefender) .. sRRNodeName;
										nodeRR = DB.findNode(sNodeRR);
									end
									
									ActionResistance.performRoll(nil, rActor, ActionRMDice.OpenEnded, nodeRR, sRealm);
								end
							else
								Comm.deliverChatMessage({icon="error", font="systemfont", text="There is no target for this table result.", secret=true});
							end

							if window.parentcontrol.getName() == "resultgrid" then
								for _, win in ipairs(window.parentcontrol.window.resultlist.getWindows()) do
									local sName = win.name.getValue();
									local sSeverity = win.severity.getValue();
									if (sName == window.parentcontrol.window.resultgrid_name 
												and sSeverity == window.parentcontrol.window.resultgrid_severity)
												or (sName == "Fumble") then
										win.applied.setValue(1);
									end
								end
								local aCrit = nil;
								local nCritOrder = 9;
								for nCrit, win in ipairs(window.parentcontrol.window.resultlist.getWindows()) do
									if win.applied.getValue() ==0 and nCrit and nCritOrder and nCrit &lt; nCritOrder then
										aCrit = { 	ResultTable = win.resulttable.getValue(), 
													Severity = win.severity.getValue(), 
													Name = win.name.getValue(), 
													Code = win.code.getValue(),
													Modifier = win.modifier.getValue()
												};
										nCritOrder = nCrit;
									end
								end
								if aCrit then
									window.parentcontrol.window.attackgrid.subwindow.criticalSelected(aCrit);

									local rActor = ActorManager.resolveActor(nodeAttacker);
									if aCrit and aCrit.ResultTable ~= Rules_Constants.RRTableID and not ActorManager.isPC(rActor) and (sTRAROption == string.lower(Interface.getString("option_val_all_criticals")) 
													or sTRAROption == string.lower(Interface.getString("option_val_all_criticals_fumbles"))) then 
										ActionResultTable.performRoll(draginfo, rActor, aCrit.ResultTable);
									end
								else
									window.parentcontrol.window.resultgrid.subwindow.clear();
								end
							end
						else
							Comm.deliverChatMessage({icon="error", font="systemfont", text="No table cell is selected on the table.", secret=true});
						end
					end
				</script>
			</button_text>
		</sheetdata>
	</windowclass>
</root>
