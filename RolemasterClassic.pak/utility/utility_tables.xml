			<!-- ATTACK TABLE -->
			<tableview name="attackgrid">
				<anchored to="contentframe" position="over">
					<left offset="140" />
					<bottom offset="-220" />
				</anchored>
				<script>
					local tabledata = nil;

					function bound(tablenode)
						window.setResultVisible(false);
						tabledata = getTableData();
					end

					function instanceCreated(source)
						setActive(true);
					end

					function rowSelected(roll)
						--[[ amend the modifier list to reflect the new roll ]]
						window.setFudge(roll);
					end

					function criticalSelected(crit)
						if not crit then
							return;
						end

						Rules_Combat.SetFumble();
						if crit and crit.Name=="Fumble" and tabledata and tabledata.Fumble then
							local sFumbleTableID, sFumbleColumn = Rules_Combat.GetFumbleTableInfo();
							if not sFumbleTableID or sFumbleTableID == "" then
								sFumbleTableID = tabledata.Fumble.ResultTable;
							end
							if not sFumbleColumn or sFumbleColumn == "" then
								sFumbleColumn = tabledata.Fumble.ColumnTitle;
							end
							local node = RMTableManager.getNode(sFumbleTableID);
							local column = sFumbleColumn;
							if node then
								window.resultgrid.bind(node, nil, "resultgrid");
								--[[ select initial fumble column ]]
								window.resultgrid.selectColumn(column);
								window.resultgrid.showSelection();
								local nResultTotal = window.result_total.getValue();
								window.resultgrid.selectRow(nResultTotal, nResultTotal);
							end
						elseif crit.ResultTable then
							local node = RMTableManager.getNode(crit.ResultTable);
							if crit.Modifier then
								window.crit_mod.setValue(crit.Modifier);
							else
								window.crit_mod.setValue(0);
							end

							if node then
								window.resultgrid.bind(node, nil, "resultgrid");
								--[[ select initial severity column ]]
								window.resultgrid_resulttable = crit.ResultTable;
								window.resultgrid_name = crit.Name;
								window.resultgrid_code = crit.Code;
								window.resultgrid_severity = crit.Severity;
								
								window.resultgrid.selectColumn(crit.Severity);
								if crit.ResultTable == Rules_Constants.RRTableID then
									window.resultgrid.selectRow(Rules_Combat.nLevelDefender, Rules_Combat.nLevelDefender);
								else
									local nResultTotal = window.result_total.getValue();
									window.resultgrid.selectRow(nResultTotal, nResultTotal);
								end
								window.resultgrid.showSelection();
							end
						end
					end
				</script>
			</tableview>

			<!-- RESULT TABLE -->
			<tableview name="resultgrid">
				<anchored to="contentframe" position="over">
					<left parent="attackgrid" />
					<top parent="attackgrid" anchor="bottom" offset="1" />
				</anchored>
				<script>
					function bound(tablenode)
						local sTableID = getTableID();
						local nodeTracker = DB.findNode("combattracker");

						if tablenode then
							DB.setValue(nodeTracker, "result_tableid", "string", sTableID);
							window.setResultVisible(true);
						else
							DB.setValue(nodeTracker, "result_tableid", "string", "");
							window.setResultVisible(false);
						end
					end

					function rowSelected(roll)
						selectRow(roll,roll);
						showSelection();
					end

					function instanceCreated(source)
						setActive(true);
					end
				</script>
			</tableview>

			<resize_referencelist />
		</sheetdata>
	</windowclass>

