<root>
	<!-- Show a simple view of a table (attack or critical) -->
	<windowclass name="tablebrowser">
		<frame>referencelist</frame>
		<placement>
			<size width="570" height="575" />
		</placement>
		<sizelimits>
			<minimum width="400" height="400" />
			<dynamic />
		</sizelimits>
		<sheetdata>
			<windowmenubar_referencelist name="menubar" />

			<anchor_content_referencelist_top />
			<anchor_content_referencelist_bottom />

			<!-- NAME -->
			<area_content_framed_groupbox_top name="nameframe">
				<anchored height="20" />
			</area_content_framed_groupbox_top>
			<linkcontrol name="open">
				<anchored to="nameframe" position="insidetopleft" offset="0,0" width="20" height="20" />
				<class>tablebrowser</class>
				<closetoggle/>
				<script>
					function onDragStart(button,x,y,dragdata)
						local customData = {};
						local tablename = window.grid.getTableName();
						local tableid = window.grid.getTableID();
						local tabletype = window.grid.getTableType();
						if tablename=="" or tableid=="" then
							return;
						end

						if not dragdata.getCustomData() then
							dragdata.setType("string")
							dragdata.setStringData(tablename); 
							customData.type = "RMCTable";
							customData.tableID = tableid;
							customData.tableName = tablename;
							dragdata.setCustomData(customData);
						end
						return true;
					end
				</script>
			</linkcontrol>
			<stringcontrolX name="name">
				<anchored to="nameframe" position="insidetop" offset="0,0" height="20">
					<left offset="30" />
				</anchored>
				<font>sheettext</font>
				<static />
				<empty>(Table)</empty>
				<script>
					function onDragStart(...)
						return window.open.onDragStart(...);
					end
				</script>
			</stringcontrolX>

			<!-- TABLE -->
			<area_content_framed_groupbox name="contentframe" />
			<tableview name="grid">
				<anchored to="contentframe" position="over" />
				<notitle/>
				<script>
					function bound(nodeTable)
						window.name.setValue(RMTableManager.getTableName(nodeTable));
					end
					function instanceCreated(source)
						setActive(false);
					end
				</script>
			</tableview>

			<resize_referencelist />
		</sheetdata>
	</windowclass>

	<!-- Allow a roll to be resolved -->
	<windowclass name="tableresolver">
		<frame>referencelist</frame>
		<sizelimits>
			<minimum width="570" height="625" />
			<dynamic />
		</sizelimits>
		<softclose />
		<script>
			local fudgemod = nil;

			function onInit()
				if not Session.IsHost or not StackManager.isActive() then
					modlist.setAnchor("bottom","contentframe","bottom","absolute",0);
					stack.setVisible(false);
					stackscroller.setVisible(false);
				end
			end

			function setFudge(newtotal)
				local delta = newtotal - total.getValue();
				if fudgemod then
					delta = delta + fudgemod.bonus.getValue();
				end
				if not fudgemod then
					fudgemod = modlist.createWindow();
					fudgemod.label.setValue("Fudge");
				end
				if delta then
					fudgemod.bonus.setValue(delta);
					fudgemod.include.setValue(1);
				else
					fudgemod.close();
					fudgemod = nil;
				end
			end

			function checkFudge()
				if not fudgemod then
					return;
				end
				for i,win in ipairs(modlist.getWindows()) do
					if win==fudgemod then
						return;
					end
				end
				fudgemod = nil;
			end

			function setResultVisible(status)
				resultgrid.setVisible(status);
				if status then
					attackgrid.setResizePending();
					attackgrid.setAnchor("bottom", "contentframe", "bottom", "absolute", -220);
					attackgrid.showSelection();
				else
					attackgrid.setResizePending();
					attackgrid.setAnchor("bottom", "contentframe", "bottom", "absolute", 0);
				end
			end

			function resolve(customData,entry)
				local tableid = customData.tableID;
				local node = RMTableManager.getNode(tableid);
				local clearentry = string.lower(OptionsManager.getOption("TRCS"));
				local nFumble = customData.fumbleValue;

				if not node then
					Comm.deliverChatMessage({text="ERROR: Unable to find table. Please load the appropriate module.", font="systemfont", icon = "error"});
					return;
				end

				attackerNodeName.setValue(customData.attackerNodeName);
				attackNodeName.setValue(customData.attackDBNodeName);
				defenderNodeName.setValue(customData.defenderNodeName);
				critTableID.setValue(customData.critTableID);
				critTableName.setValue(customData.critTableName);
				largeColumnName.setValue(customData.largeColumnName);
				crit_mod.setValue(0);

				--[[ set the hits multiplier ]]
				local nHitsMult = customData.hitsMultiplier;
				if nHitsMult == 0 then
					nHitsMult = 1;
				end
				RMTableManager.SetHitsMultiplier(nHitsMult);
				multiplier.setValue(nHitsMult);

				--[[ change the window title ]]
				name.setValue(customData.title);
				--[[ clear the results grid ]]
				resultgrid.bind(nil);
				--[[ bind the attack grid to this table - check if table needs to be adjusted for the weapon fumble]]
				if nFumble and nFumble > 0 then
					attackgrid.bind(node, nFumble, "attackgrid");
				else
					attackgrid.bind(node, nil, "attackgrid");
				end
				--[[ set the basic roll ]]
				roll.setValue(customData.dieResult);
				--[[ set the maximum result ]]
				maximum.setValue(Rules_Combat.GetMaxResultTotal(customData.maxResultLevel));
				--[[ set the unmodified roll ]]
				unmodified.setValue(Rules_Combat.nUnmodifiedRoll);


				--[[ add items in the modifier stack ]]
				if not customData.modifiers then
					customData.modifiers = {};
				end

				fudgemod = nil;
				modlist.closeAll();
				for i,mod in ipairs(customData.modifiers) do
					local win = modlist.createWindow();
					win.label.setValue(mod.description);
					win.label.setTooltipText(mod.description);
					win.bonus.setValue(mod.number);
					win.include.setValue(1);
				end
				modlist.applySort();

				--[[ select the armour type ]]
				if customData.tableColumn and customData.tableID ~= Rules_Constants.BaseSpellAttackTableID and customData.tableID ~= Rules_Constants.SpellFailureNonAttackTableID then
					attackgrid.selectColumn(customData.tableColumn);
					attackgrid.showSelection();
				elseif customData.columnTitle then
				--[[ select column title ]]
					attackgrid.selectColumn(customData.columnTitle);
					attackgrid.showSelection();
				end
				--[[ clear the stack entry ]]
				if entry and clearentry and clearentry == string.lower(Interface.getString("option_val_on")) then
					entry.deleteflag.setValue(1);
					stack.applyFilter();
				end
				if attackgrid.getTableID() == Rules_Constants.RRTableID and Rules_Combat.nLevelActor &gt; 0 then
					attackgrid.selectRow(Rules_Combat.nLevelActor, Rules_Combat.nLevelActor);
					attackgrid.selectColumn(Rules_Combat.nLevelActor);
				end

			end
		</script> 
		<sheetdata>
			<windowtitlebar_referencelist name="title">
				<resource>tr_window_title</resource>
			</windowtitlebar_referencelist>
			<windowmenubar_referencelist name="menubar" />

			<anchor_content_referencelist_top />
			<anchor_content_referencelist_bottom />

			<hsc name="attackerNodeName">
				<script>
					function onValueChanged()
						local nodeAttacker = DB.findNode(getValue());
						if nodeAttacker then
							local rActor = ActorManager.resolveActor(nodeAttacker);
							if rActor then
								window.attacker_link.setValue(ActorManager.getRecordType(rActor), ActorManager.getCreatureNodeName(rActor));
								window.attacker_link.setVisible(true);
							else
								window.attacker_link.setValue(nil);
								window.attacker_link.setVisible(false);
							end
							window.attacker_name.setValue(DB.getValue(nodeAttacker, "name", ""));
						else
							window.attacker_link.setValue(nil);
							window.attacker_link.setVisible(false);
							window.attacker_name.setValue("");
						end
					end
				</script>
			</hsc>
			<hsc name="attackNodeName" />
			<hsc name="defenderNodeName">
				<script>
					function onValueChanged()
						local nodeDefender = DB.findNode(getValue());
						if nodeDefender then
							local rActor = ActorManager.resolveActor(nodeDefender);
							if rActor then
								window.defender_link.setValue(ActorManager.getRecordType(rActor), ActorManager.getCreatureNodeName(rActor));
								window.defender_link.setVisible(true);
							else
								window.defender_link.setValue(nil);
								window.defender_link.setVisible(false);
							end
							window.defender_name.setValue(DB.getValue(nodeDefender, "name", ""));
							window.crit_mod_description.setValue(DB.getValue(nodeDefender, "critmod", ""));
							window.crit_mod.setValue(0);
						else
							window.defender_link.setValue(nil);
							window.defender_link.setVisible(false);
							window.defender_name.setValue("");
							window.crit_mod_description.setValue("");
							window.crit_mod.setValue(0);
						end
					end
				</script>
			</hsc>
			<hsc name="critTableID" />
			<hsc name="critTableName" />
			<hsc name="largeColumnName" />
		
			<!-- NAME CONTENT -->
			<area_content_framed_groupbox_top name="nameframe">
				<anchored height="10"/>
			</area_content_framed_groupbox_top>
			<stringcontrolX name="name">
				<anchored to="nameframe" position="insidetopleft" offset="0,-5" height="20">
					<right offset="10" />
				</anchored>
				<font>sheettext</font>
				<static />
				<empty>(Table Resolver)</empty>
			</stringcontrolX>

			<button_text name="button_reset">
				<anchored to="nameframe" position="aboveleft" offset="-5,20" width="50" height="20" />
				<state textres="tr_label_reset" />
				<tooltip textres="tr_tooltip_reset" />
				<script>
					function onButtonPress()
						window.name.setValue("(Table Resolver)");
						window.attackgrid.subwindow.clear();
						window.resultgrid.bind(nil);
						window.modlist.closeAll();
						window.roll.setValue(0);
						window.unmodified.setValue(0);
						window.multiplier.setValue(1);
						window.attackerNodeName.setValue("");
						window.defenderNodeName.setValue("");
						window.crit_mod_description.setValue("");
						window.crit_mod.setValue(0);
						window.result_roll.setValue(1);
						window.resultlist.closeAll();
					end
				</script>
			</button_text>

			<!-- WINDOW CONTENT -->
			<area_content_framed_groupbox name="contentframe" />

			<!-- ATTACK GRID INFO -->
			<header_section_tableresolver name="header_attack">
				<static textres="tr_ag_header_attack_grid" />
				<tooltip textres="tr_ag_tooltip_attack_grid" />
			</header_section_tableresolver>
			<!-- ROLL, MOD AND TOTAL -->
			<numberc_tableresolver name="roll">
				<anchored to="header_attack" position="belowleft" offset="6,12" height="18" />
				<script>
					function onValueChanged()
						if window.total and window.total.recalc then
							window.total.recalc();
						end
					end

					function onDrop(x, y, draginfo)
						if draginfo.getType() == "rmdice" then
							setValue(draginfo.getNumberData());
						end
					end
				</script>
			</numberc_tableresolver>
			<stringc_labeltop_tableresolver name="roll_label">
				<anchored to="roll" />
				<static textres="tr_ag_label_roll" />
				<tooltip textres="tr_ag_tooltip_roll" />
			</stringc_labeltop_tableresolver>
			<numberc_tableresolver name="mods">
				<anchored to="roll" />
				<displaysign/>
				<readonly/>
				<frame name="fielddark" offset="4,4,4,4" />
			</numberc_tableresolver>
			<stringc_labeltop_tableresolver name="mods_label">
				<anchored to="mods" />
				<static textres="tr_ag_label_mods" />
				<tooltip textres="tr_ag_tooltip_mods" />
			</stringc_labeltop_tableresolver>
			<numberc_tableresolver name="total">
				<anchored to="mods" />
				<readonly/>
				<frame name="fielddark" offset="4,4,4,4" />
				<script>
					local nOldTotal = 0;
					local nOldUnmodified = 0;

					function recalc()
						local nRoll = window.roll.getValue();
						local nMod = window.mods.getValue();
						local nTotal = nRoll + nMod;
						local nMax = window.maximum.getValue();
						local nUnmodified = window.unmodified.getValue();

						if nTotal &gt; nMax and nMax &lt; 150 then
							nTotal = nMax;
						end
						if nTotal &gt; 150 then
							local nAmountOver = nTotal - 150;
						end
						setValue(nTotal);
						--[[ update the attack grid highlighting ]]
						if window.attackgrid and (nOldTotal ~= nTotal or nOldUnmodified ~= nUnmodified) then
							nOldTotal = nTotal;
							nOldUnmodified = nUnmodified;
							window.attackgrid.selectRow(nUnmodified, nTotal);
							window.attackgrid.showSelection();
						end
					end
				</script>
			</numberc_tableresolver>
			<stringc_labeltop_tableresolver name="total_label">
				<anchored to="total" />
				<static textres="tr_ag_label_total" />
				<tooltip textres="tr_ag_tooltip_total" />
			</stringc_labeltop_tableresolver>

			<numberc_tableresolver name="unmodified">
				<anchored to="roll" position="belowleft" offset="0,12" height="18" />
				<script>
					function onValueChanged()
						Rules_Combat.nUnmodifiedRoll = getValue();
						if window.total and window.total.recalc then
							window.total.recalc();
						end
					end
				</script>
			</numberc_tableresolver>
			<stringc_labeltop_tableresolver name="unmodified_label">
				<anchored to="unmodified" />
				<static textres="tr_ag_label_unmodified" />
				<tooltip textres="tr_ag_tooltip_unmodified" />
			</stringc_labeltop_tableresolver>
			<numberc_tableresolver name="multiplier">
				<anchored to="unmodified" />
				<frame name="fielddark" offset="4,4,4,4" />
				<default>1</default>
				<readonly/>
			</numberc_tableresolver>
			<stringc_labeltop_tableresolver name="multiplier_label">
				<anchored to="multiplier" />
				<static textres="tr_ag_label_multiplier" />
				<tooltip textres="tr_ag_tooltip_multiplier" />
			</stringc_labeltop_tableresolver>
			<numberc_tableresolver name="maximum">
				<anchored to="multiplier" />
				<script>
					function onValueChanged()
						if window.total and window.total.recalc then
							window.total.recalc();
						end
					end
				</script>
			</numberc_tableresolver>
			<stringc_labeltop_tableresolver name="maximum_label">
				<anchored to="maximum" />
				<static textres="tr_ag_label_maximum" />
				<tooltip textres="tr_ag_tooltip_maximum" />
			</stringc_labeltop_tableresolver>

			<!-- ATTACKER, DEFENDER AND CRIT MOD -->
			<stringc_labeled_tr name="attacker_name">
				<anchored to="unmodified" position="belowleft" offset="-5,-1" width="116" height="20" />
				<labelres>tr_ag_label_attacker</labelres>
				<tooltip textres="tr_ag_tooltip_attacker" />
				<script>
					function onDrop(x, y, draginfo)
						local nodeAttacker = DB.findNode(window.attackerNodeName.getValue());
						if nodeAttacker then
							local nodeCT = ActorManager.getCTNode(nodeAttacker);
							if nodeCT then
								CombatManager2.CTNodeOnDrop(nodeCT, draginfo);
							end
						end
					end
				</script>
			</stringc_labeled_tr>
			<linkfield_tableresolver name="attacker_link">
				<anchored to="attacker_name" />
				<description field="attacker_name" />
			</linkfield_tableresolver>
			<stringc_labeled_tr name="defender_name">
				<anchored to="attacker_name" position="belowleft" offset="0,4" width="116" height="20" />
				<labelres>tr_ag_label_defender</labelres>
				<tooltip textres="tr_ag_tooltip_defender" />
				<script>
					function onDrop(x, y, draginfo)
						local nodeDefender = DB.findNode(window.defenderNodeName.getValue());
						if nodeDefender then
