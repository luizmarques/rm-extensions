			</stringc_labeled_tr>
			<linkfield_tableresolver name="defender_link">
				<anchored to="defender_name" />
				<description field="defender_name" />
			</linkfield_tableresolver>

			<!-- MODIFIER LIST -->
			<header_section_tableresolver name="header_modifiers">
				<anchored>
					<top parent="defender_name" anchor="bottom" offset="9" />
				</anchored> 
				<static textres="tr_mod_header_modifiers" />
				<tooltip textres="tr_mod_tooltip_modifiers" />
			</header_section_tableresolver>
			<windowlist name="modlist">
				<anchored to="header_modifiers" position="belowleft" offset="1,2" width="137" height="100" />
				<frame name="rowshade" />
				<class>tableview_modentry</class>
				<sortby>
					<control>label</control>
					<field>bonus</field>
				</sortby>
				<allowcreate />
				<allowdelete />
				<script>
					function onInit()
						update();
					end

					function onMenuSelection(level1)
						if level1==7 then
							closeAll();
						end
					end

					function update()
						resetMenuItems();
						if #(getWindows())~=0 then
							registerMenuItem("Clear All","clearall",7);
						end

						--[[ recalc the modlist total ]]
						local total = 0;
						for i,mod in ipairs(getWindows()) do
							if mod.include.getValue() == 1 then
								total = total + mod.bonus.getValue();
							end
						end
						window.mods.setValue(total);
						window.total.recalc();
					end

					function onListRearranged(changed)
						if changed then
							window.checkFudge();
							update();
						end
					end

					function onDrop(x,y,dragdata)
						if dragdata.isType("number") then

							local win = createWindow();
							if dragdata.getNumberData() then
								win.bonus.setValue(dragdata.getNumberData());
							end
							if dragdata.getDescription() then
								win.label.setValue(dragdata.getDescription());
							elseif dragdata.getStringData() then
								win.label.setValue(dragdata.getStringData());
							end
							win.include.setValue(1);
							return true;
						else
							return false;
						end
					end
				</script>
			</windowlist>
			<RMC_scrollbar name="modscroller">
				<anchored>
					<to>modlist</to>
					<position>right</position>
					<offset>-9,-4</offset>
				</anchored>
				<target>modlist</target>
			</RMC_scrollbar>

			<!-- RESULT GRID INFO -->
			<hsc name="resultgrid_resulttable" />
			<hsc name="resultgrid_name" />
			<hsc name="resultgrid_code" />
			<hsc name="resultgrid_severity" />
			<header_section_tableresolver name="header_result">
				<anchored>
					<top parent="modlist" anchor="bottom" offset="2" />
				</anchored> 
				<static textres="tr_rg_header_result_grid" />
				<tooltip textres="tr_rg_tooltip_result_grid" />
			</header_section_tableresolver>
			<numberc_tableresolver name="result_roll">
				<anchored to="header_result" position="belowleft" offset="6,12" height="18" />
				<default>1</default>
				<script>
					function onValueChanged()
						window.result_total.recalc();
					end

					function onDrop(x, y, draginfo)
						if draginfo.getType() == "rmdice" or draginfo.getType() == "resulttable" then
							setValue(draginfo.getNumberData());
						end
					end

					function action(draginfo)
						local rActor = ActorManager.resolveActor(nil);
						local sTableID = window.resultgrid.getTableID();

						ActionResultTable.performRoll(draginfo, rActor, sTableID);

						return true;
					end
					function onDragStart(button, x, y, draginfo)
						return action(draginfo);
					end
					function onDoubleClick(x,y)
						return action();
					end
				</script>
			</numberc_tableresolver>
			<stringc_labeltop_tableresolver name="result_roll_label">
				<anchored to="result_roll" />
				<static textres="tr_rg_label_roll" />
				<tooltip textres="tr_rg_tooltip_roll" />
			</stringc_labeltop_tableresolver>
			<dice_ghost name="diceholder">
				<anchored to="result_roll" position="over" />
				<disabled />
			</dice_ghost>
			<numberc_tableresolver name="crit_mod">
				<anchored to="result_roll" />
				<labelres>tr_label_crit_mod</labelres>
				<script>
					function onValueChanged()
						window.result_total.recalc();
					end
				</script>
			</numberc_tableresolver>
			<stringc_labeltop_tableresolver name="crit_mod_label">
				<anchored to="crit_mod" />
				<static textres="tr_rg_label_crit_mod" />
				<tooltip textres="tr_rg_tooltip_crit_mod" />
			</stringc_labeltop_tableresolver>
			<numberc_tableresolver name="result_total">
				<anchored to="crit_mod" />
				<readonly/>
				<frame name="fielddark" offset="4,4,4,4" />
				<script>
					local nOldTotal = 0;
					
					function onInit()
						recalc();
					end

					function recalc()
						local nResultRoll = window.result_roll.getValue();
						local nCritMod = window.crit_mod.getValue();
						local nResultTotal  = nResultRoll + nCritMod;
						
						if nResultTotal &lt; 1 then
							nResultTotal = 1;
						end
						
						setValue(nResultTotal);
						
						--[[ update the result grid ]]
						if window.resultgrid and (nOldTotal ~= nResultTotal) then
							nOldTotal = nResultTotal;
							window.resultgrid.selectRow(nResultTotal, nResultTotal);
							window.resultgrid.showSelection();
						end
					end
				</script>
			</numberc_tableresolver>
			<stringc_labeltop_tableresolver name="result_total_label">
				<anchored to="result_total" />
				<static textres="tr_rg_label_total" />
				<tooltip textres="tr_rg_tooltip_total" />
			</stringc_labeltop_tableresolver>
		
			<stringc_labeled_tr name="crit_mod_description">
				<anchored to="result_roll" position="belowleft" offset="-5,-1" width="136" height="20" />
				<labelres>tr_rg_label_crit_mod_description</labelres>
				<tooltip textres="tr_rg_tooltip_crit_mod_description" />
			</stringc_labeled_tr>

