				</anchored>
				<frame>
					<name>rowshade</name>
				</frame>
				<datasource>stack</datasource>
				<class>tableview_stackentry</class>
				<allowdelete/>
				<script>
					function onInit()
						for _,node in ipairs(DB.getChildList(getDatabaseNode())) do
							if DB.getValue(node, "deleteflag", 0) == 1 then
								DB.deleteNode(node);
							end
						end
						checkMenu();
					end

					function checkMenu()
						resetMenuItems();
						if #(getWindows())~=0 then
							registerMenuItem("Clear Stack","clearstack",7);
						end
					end

					function onListRearranged(changed)
						if changed then
							checkMenu();
						end
					end

					function onMenuSelection(selection)
						if selection == 7 then
							DB.deleteChildren(getDatabaseNode());
						end
					end

					function onFilter(win)
						if win.deleteflag.getValue()==1 then
							return false;
						else
							return true;
						end
					end
				</script>
			</windowlist>
