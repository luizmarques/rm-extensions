<root>
	<windowclass name="charsheet_notes">
		<script>
			function onInit()
				if super and super.onInit then
					super.onInit();
				end
				if Session.IsHost then
					--[[ GM view, include GM notes ]]
					notesframe.setAnchor("bottom", "", "bottom", "absolute", -220);
				else
					--[[ Player view, exclude GM notes ]]
					notesframe.setAnchor("bottom", "", "bottom", "absolute", -10);
				end
			end
		</script>
		<sheetdata>
			<anchor_content_top />
			<anchor_content_bottom />

			<!-- APPEARANCE -->
			<area_content_framed_groupbox_top name="appearanceframe">
				<anchored height="75" />
			</area_content_framed_groupbox_top>
			<label>
				<anchored to="appearanceframe" position="insidetop" />
				<static textres="char_heading_appearance_description" />
				<center />
			</label>
			<stringu name="appearancedesc">
				<anchored to="appearanceframe" position="insidetop" offset="0,15">
					<bottom />
				</anchored>
				<multilinespacing>20</multilinespacing>
			</stringu>
			<scrollbar_content_base>
				<anchored to="appearancedesc" />
				<target>appearancedesc</target>
			</scrollbar_content_base>

			<!-- GM NOTES -->
			<area_content_framed_groupbox_bottom name="gmframe">
				<anchored height="175" />
			</area_content_framed_groupbox_bottom>
			<label name="gmframelabel">
				<anchored to="gmframe" position="insidetop" />
				<static textres="char_heading_gm_notes" />
				<center />
				<gmvisibleonly />
			</label>
			<stringu name="gmnotes">
				<anchored to="gmframe" position="insidetop" offset="0,15">
					<bottom />
				</anchored>
				<multilinespacing>20</multilinespacing>
				<gmvisibleonly />
			</stringu>
			<scrollbar_content_base>
				<anchored to="gmnotes" />
				<target>gmnotes</target>
				<gmvisibleonly />
			</scrollbar_content_base>

			<!-- PLAYER NOTES -->
			<area_content_framed_groupbox name="notesframe" />
			<label>
				<anchored to="notesframe" position="insidetop" />
				<static textres="char_heading_notes" />
				<center />
			</label>
			<stringu name="notes">
				<anchored to="notesframe" position="insidetop" offset="0,20">
					<bottom />
				</anchored>
				<multilinespacing>20</multilinespacing>
			</stringu>
			<scrollbar_content_base>
				<anchored to="notes" />
				<target>notes</target>
			</scrollbar_content_base>
		</sheetdata>
	</windowclass>
</root>
