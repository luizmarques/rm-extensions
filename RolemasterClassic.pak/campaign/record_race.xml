		<script>
			function updateDropDown(sControl, sDropDown)
				if self[sControl].isReadOnly() then
					self[sDropDown].setVisible(false);
				else
					self[sDropDown].setVisible(true);
				end	
			end
			function update()
				local bReadOnly = WindowManager.getReadOnlyState(getDatabaseNode());
				
				constitution.setReadOnly(bReadOnly);
				agility.setReadOnly(bReadOnly);
				selfdiscipline.setReadOnly(bReadOnly);
				memory.setReadOnly(bReadOnly);
				reasoning.setReadOnly(bReadOnly);
				strength.setReadOnly(bReadOnly);
				quickness.setReadOnly(bReadOnly);
				presence.setReadOnly(bReadOnly);
				intuition.setReadOnly(bReadOnly);
				empathy.setReadOnly(bReadOnly);

				essence.setReadOnly(bReadOnly);
				channeling.setReadOnly(bReadOnly);
				mentalism.setReadOnly(bReadOnly);
				poison.setReadOnly(bReadOnly);
				disease.setReadOnly(bReadOnly);
				terror.setReadOnly(bReadOnly);

				souldep.setReadOnly(bReadOnly);
				statdec.setReadOnly(bReadOnly);
				recx.setReadOnly(bReadOnly);
				languages.setReadOnly(bReadOnly);
				hitdie.setReadOnly(bReadOnly);
				maxhits.setReadOnly(bReadOnly);

				backgroundoptions.setReadOnly(bReadOnly);
				racialleveloffset_BGO.setReadOnly(bReadOnly);
				racialleveloffset_no_BGO.setReadOnly(bReadOnly);
				senses.setReadOnly(bReadOnly);
				WindowManager.callSafeControlUpdate(self, "deathmarker", bReadOnly);
				self["deathmarker"].setComboBoxReadOnly(bReadOnly);

				description.setReadOnly(bReadOnly);
			end
		</script>
