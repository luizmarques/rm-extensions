	<!-- Profession -->
	<template name="list_column_prof_skillcost">
		<list_column>
			<anchored>
				<top parent="columnanchor" anchor="bottom" relation="relative" offset="15" />
			</anchored>
			<allowdelete merge="delete" />
			<class>prof_skillcost_item</class>
			<script>
				function onFilter(w)
					local node = w.getDatabaseNode();
					local sModuleName = DB.getValue(node, "modulename", "");
					local bFilter = false;
					if sModuleName then
						local aModule = Module.getModuleInfo(sModuleName);
						if sModuleName == "" or (aModule and aModule.loaded) then
							bFilter = true;
						end
					end
					return bFilter;
				end
			</script>
		</list_column>  
	</template>
