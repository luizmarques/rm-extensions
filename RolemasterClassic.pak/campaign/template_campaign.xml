	<template name="combobox_column_tablename">
		<combobox_column>
			<listmaxsize mergerule="replace">10</listmaxsize>
			<frame>
				<name>fielddark</name>
				<offset>7,5,7,5</offset>
				<hidereadonly>true</hidereadonly>
			</frame>
			<script>
				function onValueChanged()
					local sTableName = getValue();
					local sTableID = Rules_Tables.GetTableID(sTableName);
					
					if sTableID and sTableID ~= "" then
						local nodeParent = DB.getParent(getDatabaseNode());
						if nodeParent then
							DB.setValue(nodeParent, "tableid", "string", sTableID);
						end
					end
				end
			</script>
		</combobox_column>
	</template>
