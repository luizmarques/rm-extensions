<root>
	<template name="combobox_labeled_RMC">
		<stringfield>
			<font>sheettext</font>
			<controlline />
			<listdirection mergerule="replace">down</listdirection>
			<listmaxsize>10</listmaxsize>
			<buttonoffset mergerule="replace">0,-1</buttonoffset>
			<script file="common/scripts/combobox_labeled_RMC.lua"/>
		</stringfield>
	</template>
	<template name="combobox_button_RMC">
		<genericcontrol>
			<anchored width="15" height="10">
				<top />
				<right />
			</anchored>
			<invisible />
			<script file="common/scripts/combobox_button_RMC.lua"/>
		</genericcontrol>
	</template>

 	<template name="combobox_list_RMC">
		<windowlist>
			<anchored height="50">
				<right />
				<bottom />
			</anchored>
			<frame name="combobox_list" offset="2,2,2,2" />
			<datasource/>
			<class>comboxbox_item_RMC</class>
			<invisible/>
			<sortby><control>Order</control></sortby>
			<script file="common/scripts/combobox_list_RMC.lua" />
		</windowlist>
	</template>
 	<template name="combobox_list_sorted_RMC">
		<combobox_list_RMC>
			<sortby merge="replace"><control>Text</control></sortby>
		</combobox_list_RMC>
	</template>
 	<template name="combobox_scrollbar_RMC">
		<scrollbarcontrol>
			<anchored position="insideleft" width="10" />
			<normal name="combobox_scrollbar" />
		</scrollbarcontrol>
	</template>
    <windowclass name="comboxbox_item_RMC">
		<script file="common/scripts/combobox_item_RMC.lua" />
		<sheetdata>
			<hnc name="Order" />
			<hsc name="Value" />

			<simplestring name="Text">
				<anchored position="insidetop" height="20" />
				<readonly />
				<script>
					function onClickDown()
						return true;
					end

					function onClickRelease()
						window.clicked();
					end
				</script>
			</simplestring>
		</sheetdata>
	</windowclass>
</root>
