		</resize>
	</template>
	<template name="tabs_partysheet">
		<buttongroup_tabs name="tabs">
			<anchored width="18" height="92">
				<top offset="50" />
				<right offset="0" />
			</anchored>
		</buttongroup_tabs>
	</template>

