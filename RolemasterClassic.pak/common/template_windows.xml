<root>
	<!-- DESKTOP PANELS -->

	<!-- Frame: chatbox -->
	<template name="resize_chatbox">
		<resize>
			<anchored>
				<right offset="-17" />
				<bottom offset="-7" />
			</anchored>
		</resize>
	</template>
	<template name="anchor_content_chatbox_top">
		<genericcontrol name="contentanchor">
			<anchored height="0">
				<top offset="26" />
				<left offset="22" />
				<right offset="-36" />
			</anchored>
			<disabled />
		</genericcontrol>
	</template>
	<template name="anchor_content_chatbox_bottom">
		<genericcontrol name="bottomanchor">
			<anchored to="contentanchor" height="23">
				<bottom parent="" />
				<left />
				<right />
			</anchored>
			<disabled />
		</genericcontrol>
	</template>

	<!-- FLOATING WINDOWS - UTILITY -->

	<!-- Frame: tokenbag -->
	<template name="windowtitlebar_tokenbag">
		<windowtitlebar>
			<anchored offset="0,0" />
		</windowtitlebar>
	</template>
	<template name="windowmenubar_tokenbag">
		<windowmenubar>
			<anchored offset="-7,7">
				<left offset="6" />
			</anchored>
		</windowmenubar>
	</template>
	<template name="resize_tokenbag">
		<resize>
			<anchored>
				<right offset="-5" />
				<bottom offset="-1" />
			</anchored>
		</resize>
	</template>
	<template name="anchor_content_tokenbag_top">
		<genericcontrol name="contentanchor">
			<anchored height="0">
				<top offset="45" />
				<left offset="30" />
				<right offset="-33" />
			</anchored>
			<disabled />
		</genericcontrol>
	</template>
	<template name="anchor_content_tokenbag_bottom">
		<genericcontrol name="bottomanchor">
			<anchored to="contentanchor" height="20">
				<bottom parent="" />
				<left />
				<right />
			</anchored>
			<disabled />
		</genericcontrol>
	</template>

