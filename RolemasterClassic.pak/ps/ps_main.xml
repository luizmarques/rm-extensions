			<number_ps_rrbonus name="ment_ess">
				<anchored to="mentalism" position="belowleft" offset="0,3" />
			</number_ps_rrbonus>
			<number_ps_rrbonus name="arcane">
				<anchored to="poison" position="belowleft" offset="0,3" />
