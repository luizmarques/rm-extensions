					<bottom />
				</anchored>
				<multilinespacing>20</multilinespacing>
			</stringu>
			<scrollbar_content_base>
				<anchored to="spelllvleps" />
				<target>spelllvleps</target>
			</scrollbar_content_base>

			<!-- Successful Maneuvers Eps -->
			<area_content_framed_groupbox_top name="successfulmaneuverseps">
				<anchored to="contentanchor" position="insidetopleft" offset="0,0" height="140" />
			</area_content_framed_groupbox_top>
			<label name="successfulmaneuverseps">
				<anchored to="successfulmaneuverseps" position="insidetop" />
				<static>Successful Maneuvers Eps</static>
				<center />
			</label>
			<stringu name="successfulmaneuverseps">
				
				<anchored to="successfulmaneuverseps" position="insidetop" offset="0,20">
					<bottom />
				</anchored>
				<multilinespacing>20</multilinespacing>
			</stringu>
			<scrollbar_content_base>
				<anchored to="successfulmaneuverseps" />
				<target>successfulmaneuverseps</target>
			</scrollbar_content_base>

			<!-- Combat Eps -->
			<area_content_framed_groupbox_top name="combateps">
				<anchored to="contentanchor" position="insidetopleft" offset="0,0" height="140" />
			</area_content_framed_groupbox_top>
			<label name="combateps">
				<anchored to="combateps" position="insidetop" />
				<static>Combat Eps</static>
				<center />
			</label>
			<stringu name="combateps">
				
				<anchored to="combateps" position="insidetop" offset="0,20">
					<bottom />
				</anchored>
				<multilinespacing>20</multilinespacing>
			</stringu>
			<scrollbar_content_base>
				<anchored to="combateps" />
				<target>combateps</target>
			</scrollbar_content_base>


		</sheetdata>
	</windowclass>
</root>
